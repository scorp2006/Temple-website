# ----------------------------------------------------------------------------
# Sri Jagajjanani Temple - Backend environment variables
# Copy this file to ".env" and fill in real values.
# ----------------------------------------------------------------------------

# --- Database (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# Local example:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/temple?schema=public"
# Production example (Aiven/Render/Supabase usually require sslmode=require):
# DATABASE_URL="postgresql://user:pass@host:5432/temple?sslmode=require"

# --- Server ---
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS="http://localhost:3000"

# --- Auth ---
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- Payments (Razorpay) ---
# Leave PAYMENTS_MODE=mock to use the built-in fake payment gateway (no keys needed).
# Set to "razorpay" and fill keys to use the real gateway.
PAYMENTS_MODE=mock
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# --- Slot reservation ---
# How many minutes a slot is held while the devotee pays before auto-release.
RESERVATION_HOLD_MINUTES=10
